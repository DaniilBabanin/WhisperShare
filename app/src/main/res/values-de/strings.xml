    <!-- Performance -->
    <string name="gpu_title">GPU verwenden, wenn verfügbar</string>
    <string name="gpu_subtitle">Vulkan-Beschleunigung auf Pixel 9 (Mali-G715). Fällt automatisch auf CPU zurück, wenn der Build kein Vulkan enthält.</string>
    <string name="high_quality_title">Hochqualitätsmodus</string>
    <string name="high_quality_subtitle">Beam-Search statt Greedy-Decoding. Langsamer, aber deutlich besser bei verrauschten oder akzentuierten Aufnahmen.</string>
    <string name="threads_title">CPU-Threads · %1$s</string>
