    <!-- Home -->
    <string name="home_intro">Teile eine Sprachnachricht an WhisperShare, um sie lokal auf diesem Gerät zu transkribieren. Die gesamte Verarbeitung findet auf deinem Handy statt — keine Audiodaten verlassen das Gerät.</string>
    <string name="section_models">Modelle</string>
    <string name="section_performance">Leistung</string>
    <string name="section_language">Sprache</string>
    <string name="share_tip">Tipp: Halte eine Sprachnachricht in WhatsApp / Telegram / Signal lange gedrückt und wähle Teilen → WhisperShare.</string>
    <string name="delete_cd">Löschen</string>
    <string name="download_cd">Herunterladen</string>

    <!-- Import -->
    <string name="import_model_button">.bin-Datei importieren</string>
    <string name="import_model_hint">Lade eine bereits auf diesem Gerät vorhandene whisper.cpp ggml-Datei. Nützlich, wenn huggingface.co nicht erreichbar ist.</string>
